# Copy to .env.local (git-ignored) and fill in.
# PDS_STUB=true returns canned data — good for offline demos.
# Flip to false and set PDS_API_KEY to call the real NHS PDS FHIR Sandbox.

PDS_STUB=false
PDS_BASE_URL=https://sandbox.api.service.nhs.uk/personal-demographics/FHIR/R4
PDS_API_KEY=

LOG_LEVEL=INFO
VERSION=0.1.0
